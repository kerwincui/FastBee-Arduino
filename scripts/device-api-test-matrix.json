      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "device-config",
      "method": "GET",
      "path": "/api/device/config",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "device-info",
      "method": "GET",
      "path": "/api/device/info",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "device-time",
      "method": "GET",
      "path": "/api/device/time",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "network-status",
      "method": "GET",
      "path": "/api/network/status",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "network-config",
      "method": "GET",
      "path": "/api/network/config?compact=1",
