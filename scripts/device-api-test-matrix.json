      "path": "/api/auth/session",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "auth-multi-session",
      "type": "multi-session",
      "method": "POST",
      "path": "/api/auth/login",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "auth-bearer-over-cookie",
      "type": "bearer-over-cookie",
      "method": "GET",
      "path": "/api/auth/session",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "system-health",
      "method": "GET",
      "path": "/api/health",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "system-health-alias",
      "method": "GET",
      "path": "/api/system/health",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "system-info",
      "method": "GET",
      "path": "/api/system/info?probe=1",
      "profiles": ["lite", "standard", "full"]
    },
    {
      "name": "system-status",
      "method": "GET",
      "path": "/api/system/status",
      "profiles": ["lite", "standard", "full"]
