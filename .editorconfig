# FastBee-Arduino 编辑器配置文件
# 统一不同编辑器的代码风格设置

root = true

# 所有文件默认设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++ 文件
[*.{c,cpp,h,hpp}]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# JavaScript 文件
[*.{js,jsx}]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# CSS 文件
[*.{css,scss,less}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# JSON 文件
[*.json]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

# YAML 文件
[*.{yml,yaml}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# Python 脚本
[*.py]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# HTML 文件
[*.html]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# PlatformIO 配置文件
[platformio.ini]
indent_size = 2
indent_style = space

# 忽略的文件
[.{pio,.git,.vscode}/**]
trim_trailing_whitespace = false
insert_final_newline = false
