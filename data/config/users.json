{
  "version": "2.0",
  "users": [],
  "security": {
    "maxLoginAttempts": 5,
    "loginLockoutTime": 300000,
    "minPasswordLength": 6,
    "maxPasswordLength": 32,
    "requireStrongPasswords": false,
    "allowMultipleSessions": true,
    "sessionTimeout": 3600000,
    "sessionCleanupInterval": 60000,
    "enableSessionPersistence": true,
    "cookieName": "session",
    "cookieMaxAge": 3600,
    "cookieHttpOnly": true,
    "cookieSecure": false
  }
}
